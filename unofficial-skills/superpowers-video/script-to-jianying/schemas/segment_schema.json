{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Segment Mapping Schema",
  "type": "object",
  "required": ["version", "project_name", "canvas", "tracks", "total_duration_us"],
  "properties": {
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+$"},
    "project_name": {"type": "string"},
    "canvas": {
      "type": "object",
      "required": ["width", "height", "ratio", "fps"],
      "properties": {
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "ratio": {"type": "string"},
        "fps": {"type": "integer", "enum": [24, 30, 60]}
      }
    },
    "tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "segments"],
        "properties": {
          "id": {"type": "string"},
          "type": {"enum": ["video", "audio", "text"]},
          "segments": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "target_timerange"],
              "properties": {
                "id": {"type": "string"},
                "type": {"enum": ["text", "audio", "video", "image", "sticker", "effect", "transition", "handwrite", "chroma"]},
                "target_timerange": {
                  "type": "object",
                  "required": ["start", "duration"],
                  "properties": {
                    "start": {"type": "integer", "minimum": 0},
                    "duration": {"type": "integer", "minimum": 1}
                  }
                }
              }
            }
          }
        }
      }
    },
    "total_duration_us": {"type": "integer", "minimum": 0}
  }
}
